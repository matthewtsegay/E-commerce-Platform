# Django Security
DEBUG=False
# Generate a new SECRET_KEY for production using `python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'`
SECRET_KEY=replace-me-with-a-secure-random-key-in-production
ALLOWED_HOSTS=yourproductiondomain.com,www.yourproductiondomain.com
CORS_ALLOWED_ORIGINS=https://yourproductiondomain.com

# Database Configuration
DATABASE_URL=postgres://client:market123@localhost:5432/ecommerce_db

# Admin configuration
ADMIN_NAME=superAdmin
ADMIN_EMAIL=admin@yourproductiondomain.com

# Email configuration (SMTP)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourproductiondomain.com
EMAIL_USE_TLS=True

# Redis & Celery
REDIS_URL=redis://127.0.0.1:6379/2
CELERY_BROKER_URL=redis://127.0.0.1:6379/1

# Logging
DJANGO_LOG_LEVEL=WARNING
